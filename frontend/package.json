{
  "name": "cobblestone",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "sync-icon": "python3 ../scripts/generate-app-icons.py",
    "dev:desktop": "npm run dev --workspace @cobblestone/desktop",
    "dev:web": "npm run dev --workspace @cobblestone/web",
    "build:desktop": "npm run build --workspace @cobblestone/desktop",
    "build:web": "npm run build --workspace @cobblestone/web",
    "build": "npm run build:desktop && npm run build:web"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
