{
  "productName": "Cobblestone",
  "version": "0.1.0",
  "identifier": "dev.cobblestone.app",
  "build": {
    "beforeDevCommand": "cd ../../frontend && npm run dev --workspace @cobblestone/desktop",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ../../frontend && npm run build --workspace @cobblestone/desktop",
    "frontendDist": "../../../frontend/apps/desktop/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cobblestone",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/cobblestone.png"
    ]
  }
}
